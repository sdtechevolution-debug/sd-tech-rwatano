{
  "version": 2,
  "name": "sd-tech-frontend",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "\/(.*\.(js|css|png|jpg|jpeg|svg|webp|ico|json|map))$",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "\/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
