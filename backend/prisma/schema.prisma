generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        Role      @default(WORKER)
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sales       Sale[]
  expenses    Expense[]
  services    Service[]
  debts       Debt[]
  passwordResets PasswordReset[]
  activities  Activity[]
  mobileMoneyTransactions MobileMoneyTransaction[]
  notifications           Notification[]
}

enum Role {
  OWNER
  WORKER
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String    @id @default(cuid())
  name           String
  barcode        String?   @unique
  category       Category  @relation(fields: [categoryId], references: [id])
  categoryId     String
  description    String?
  stockQuantity  Int       @default(0)
  reorderPoint   Int       @default(5)
  buyPrice       Float
  sellPrice      Float
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  saleItems      SaleItem[]

  @@index([categoryId])
}

model Sale {
  id              String     @id @default(cuid())
  user            User       @relation(fields: [userId], references: [id])
  userId          String
  customerName    String?
  customerPhone   String?
  paymentMethod   PaymentMethod @default(CASH)
  isDebt          Boolean       @default(false)
  totalAmount     Float
  paidAmount      Float        @default(0)
  remainingAmount Float        @default(0)
  totalProfit     Float
  taxAmount       Float        @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  items           SaleItem[]
}

model SaleItem {
  id         String  @id @default(cuid())
  sale       Sale    @relation(fields: [saleId], references: [id])
  saleId     String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  quantity   Int
  unitPrice  Float
  costPrice  Float
  profit     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  category        String
  description     String?
  paymentMethod   PaymentMethod @default(CASH)
  isDebt          Boolean       @default(false)
  amount          Float
  paidAmount      Float         @default(0)
  remainingAmount Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum ServiceCategory {
  PRINTING
  PHOTOCOPY
  SCANNING
  TYPING
  INTERNET
  MOBILE_MONEY
  AIRTIME_SIM
}

model Expense {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  category    ExpenseCategory
  description String?
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ExpenseCategory {
  ELECTRICITY
  INTERNET
  TRANSPORT
  RENT
  SALARY
  MAINTENANCE
  SUPPLIES
  OTHER
}

model Debt {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  customerName   String
  customerPhone  String
  totalOwed      Float
  paidAmount     Float  @default(0)
  remainingAmount Float
  dueDate        DateTime?
  status         DebtStatus @default(OPEN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  payments       DebtPayment[]
}

enum DebtStatus {
  OPEN
  PARTIAL
  CLOSED
}

model DebtPayment {
  id        String   @id @default(cuid())
  debt      Debt     @relation(fields: [debtId], references: [id])
  debtId    String
  amount    Float
  paymentMethod PaymentMethod?
  note      String?
  createdAt DateTime @default(now())
}

model MobileMoneyTransaction {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  type        MobileTransactionType
  amount      Float
  commission  Float   @default(0)
  provider    String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MobileTransactionType {
  DEPOSIT
  WITHDRAWAL
  AIRTIME
  CASH_IN
  CASH_OUT
}

enum PaymentMethod {
  CASH
  MOMO
}

model Notification {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  action      String
  meta        Json?
  createdAt   DateTime @default(now())
}

model PasswordReset {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  tokenHash  String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([userId])
}
